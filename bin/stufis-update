#!/bin/bash
### Update StuFis to the latest release: pull, migrate and rebuild caches.
# Re-exec under bash if started via `sh stufis-update`.
[ -n "${BASH_VERSION:-}" ] || exec bash "$0" "$@"
set -e

source "$(dirname -- "${BASH_SOURCE[0]}")/stufis-common"

# puts StuFis in Maintenance Mode
step "Enabling maintenance mode"
php artisan down --with-secret

step "Clearing compiled caches"
php artisan clear-compiled
php artisan optimize:clear

# does backup of files + db
step "Backing up files + database"
php artisan backup:run --disable-notifications
php artisan backup:clean --disable-notifications
php artisan backup:list

step "Fetching latest code"
git fetch --tags --prune

if [ -n "$1" ]; then
    # deploy a specific ref: a release tag (recommended, reproducible) or a branch.
    # Prefer the tag namespace and check it out detached, so a tag never clashes
    # with a stale local branch of the same name (e.g. v4.4.0 tag vs v4.4.0 branch).
    if git rev-parse -q --verify "refs/tags/$1^{commit}" >/dev/null; then
        git checkout --detach "refs/tags/$1"
    else
        git checkout "$1"
    fi
fi

# fast-forward only when on a branch; a tag checkout is a detached HEAD with no
# upstream to pull from, so leave it pinned at that exact release.
if git symbolic-ref -q HEAD >/dev/null; then
    git pull --ff-only
fi

# install/update the toolchain (composer.phar + nvm/node/npm)
setup_tooling

step "Installing dependencies"
composer install --no-dev --optimize-autoloader
npm ci

step "Running database migrations"
php artisan migrate --force

# clear stale caches and warm the production caches
step "Rebuilding caches"
rebuild_caches

# compile tailwind css after view cache
step "Building frontend assets"
npm run build

step "Disabling maintenance mode"
php artisan up
