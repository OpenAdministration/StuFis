#!/bin/bash
# Run Laravel's artisan under the pinned PHP version. Hostsharing.net only
# exposes versioned php binaries (e.g. php8.4), so a bare `./artisan` would pick
# the system default. Being a real command on PATH (bin/ is prepended by the
# StuFis shell profile) also enables Symfony's shell completion — an alias would
# not, because the completion callback re-invokes `artisan` as a command.
exec "php${PHP_VERSION:-8.4}" "$(dirname -- "$0")/../artisan" "$@"
